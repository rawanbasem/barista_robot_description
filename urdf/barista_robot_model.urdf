<?xml version="1.0"?>
<robot name="barista_robot">

<!-- Materials -->
  <material name="red">
      <color rgba="1.0 0.0 0.0 1"/>
  </material>

  <material name="green_light">
      <color rgba="0.0 1.0 0.0 1"/>
  </material>

  <material name="green_dark">
    <color rgba="0.0 0.5 0.0 1"/>
  </material>

  <material name="blue">
      <color rgba="0.0 0.0 1.0 1"/>
  </material>

  <material name="black">
      <color rgba="0.0 0.0 0.0 1"/>
  </material>

  <material name="white">
      <color rgba="1.0 1.0 1.0 1"/>
  </material>

  <material name="box_bot_blue">
      <color rgba="0.088656 0.428691 0.491021 1"/>
  </material>

  <link name="base_link">
  </link>

<!-- Body 0.5kg -->
  <link name="chassis">
    <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.155" radius="0.178"/>
        </geometry>
        <material name="red"/>
    </visual>

    <collision>
      <geometry>
        <cylinder length="0.155" radius="0.178"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.5"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.004962" ixy="0.0" ixz="0.0" iyy="0.004962" iyz="0.0" izz="0.007921"/>
    </inertial>

  </link>

  <joint name="base_link_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0.1127" />
    <parent link="base_link" />
    <child link="chassis" />
  </joint>

<!-- Wheel Left 0.1 kg -->
  <link name="left_wheel">      
      <visual>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.0206" radius="0.0352"/>
        </geometry>
        <material name="black"/>
      </visual>

      <collision>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.0206" radius="0.0352"/>
        </geometry>
      </collision>

      <inertial>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <mass value="0.1"/>
        <inertia ixx="3.451233e-05" ixy="0" ixz="0" iyy="3.451233e-05" iyz="0" izz="6.1952e-05"/>
      </inertial>
  </link>

  <gazebo reference="left_wheel">
    <collision>
        <surface>
        <friction>
            <ode>
            <mu>10.0</mu>
            <mu2>10.0</mu2>
            </ode>
        </friction>
        <contact>
            <ode>
            <kp>10000000.0</kp>
            <kd>10000000.0</kd>
            </ode>
        </contact>
        </surface>
    </collision>
  </gazebo>


  <joint name="joint_left_wheel" type="continuous">
    <origin rpy="0 0 0" xyz="0 0.155 -0.0775"/>
    <child link="left_wheel"/>
    <parent link="chassis"/>
    <axis rpy="0 0 0" xyz="0 1 0"/>
    <limit effort="10000" velocity="1000"/>
    <joint_properties damping="1.0" friction="1.0"/>
  </joint>

<!-- Wheel Right 0.1 kg -->
  <link name="right_wheel">      
      <visual>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.0206" radius="0.0352"/>
        </geometry>
        <material name="black"/>
      </visual>

      <collision>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.0206" radius="0.0352"/>
        </geometry>
      </collision>

      <inertial>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <mass value="0.1"/>
        <inertia ixx="3.451233e-05" ixy="0" ixz="0" iyy="3.451233e-05" iyz="0" izz="6.1952e-05"/>
      </inertial>
  </link>

  <gazebo reference="right_wheel">
    <collision>
        <surface>
        <friction>
            <ode>
            <mu>10.0</mu>
            <mu2>10.0</mu2>
            </ode>
        </friction>
        <contact>
            <ode>
            <kp>10000000.0</kp>
            <kd>10000000.0</kd>
            </ode>
        </contact>
        </surface>
    </collision>
  </gazebo>

  <joint name="joint_right_wheel" type="continuous">  
    <origin rpy="0 0 0" xyz="0 -0.155 -0.0775"/>
    <child link="right_wheel"/>
    <parent link="chassis"/>
    <axis rpy="0 0 0" xyz="0 1 0"/>
    <limit effort="10000" velocity="1000"/>
    <joint_properties damping="1.0" friction="1.0"/>
  </joint>


<!-- Caster Wheel Front 0.03 kg -->
  <link name="front_yaw_link">
    <visual>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.01" radius="0.015"/>
        </geometry>
        <material name="white"/>
      </visual>

    <collision>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.01" radius="0.015"/>
        </geometry>
      </collision>

      <inertial>
          <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
          <mass value="0.001"/>
          <inertia ixx="6.4583e-08" ixy="0" ixz="0" iyy="6.4583e-08" iyz="0" izz="1.125e-07"/>
      </inertial>
  </link>

  <joint name="front_yaw_joint" type="continuous">
    <origin rpy="0 0 0" xyz="0.140 0 -0.0775" />
    <parent link="chassis" />
    <child link="front_yaw_link" />
    <axis xyz="0 0 1" />
    <limit effort="1000.0" velocity="100.0" />
    <dynamics damping="0.0" friction="0.1"/>
  </joint>


  <link name="front_roll_link">
      <visual>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.01" radius="0.015"/>
        </geometry>
        <material name="white"/>
      </visual>

      <collision>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.01" radius="0.015"/>
        </geometry>
      </collision>

      <inertial>
          <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
          <mass value="0.001"/>
          <inertia ixx="6.4583e-08" ixy="0" ixz="0" iyy="6.4583e-08" iyz="0" izz="1.125e-07"/>
      </inertial>
  </link>

  <joint name="front_roll_joint" type="continuous">
    <origin rpy="0 0 0" xyz="0 0 0" />
    <parent link="front_yaw_link" />
    <child link="front_roll_link" />
    <axis xyz="1 0 0" />
    <limit effort="1000.0" velocity="100.0" />
    <dynamics damping="0.0" friction="0.1"/>
  </joint>

  <link name="front_pitch_link">
    <visual>
      <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
      <material name="white"/>
    </visual>

    <collision>
      <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
    </collision>

    <inertial>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <mass value="0.015"/>
        <inertia ixx="1.35e-06" ixy="0" ixz="0" iyy="1.35e-06" iyz="0" izz="1.35e-06"/>
    </inertial>
  </link>

  <gazebo reference="front_pitch_link">
    <collision>
        <surface>
        <friction>
            <ode>
            <mu>0.5</mu>
            <mu2>0.5</mu2>
            </ode>
        </friction>
        <contact>
            <ode>
            <kp>10000000.0</kp>
            <kd>10000000.0</kd>
            </ode>
        </contact>
        </surface>
    </collision>
  </gazebo>

  <joint name="front_pitch_joint" type="continuous">
    <origin rpy="0 0 0" xyz="0 0 0" />
    <parent link="front_roll_link" />
    <child link="front_pitch_link" />
    <axis xyz="0 1 0" />
    <limit effort="1000.0" velocity="100.0" />
    <dynamics damping="0.0" friction="0.1"/>
  </joint>

<!-- Caster Wheel Back 0.03 kg -->
  <link name="back_yaw_link">
    <visual>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.01" radius="0.015"/>
        </geometry>
        <material name="white"/>
      </visual>

      <collision>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.01" radius="0.015"/>
        </geometry>
      </collision>

      <inertial>
          <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
          <mass value="0.001"/>
          <inertia ixx="6.4583e-08" ixy="0" ixz="0" iyy="6.4583e-08" iyz="0" izz="1.125e-07"/>
      </inertial>
  </link>

  <joint name="back_yaw_joint" type="continuous">
    <origin rpy="0 0 0" xyz="-0.140 0 -0.0775" />
    <parent link="chassis" />
    <child link="back_yaw_link" />
    <axis xyz="0 0 1" />
    <limit effort="1000.0" velocity="100.0" />
    <dynamics damping="0.0" friction="0.1"/>
  </joint>

  <link name="back_roll_link">
      <visual>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.01" radius="0.015"/>
        </geometry>
        <material name="white"/>
      </visual>

      <collision>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.01" radius="0.015"/>
        </geometry>
      </collision>

      <inertial>
          <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
          <mass value="0.001"/>
          <inertia ixx="6.4583e-08" ixy="0" ixz="0" iyy="6.4583e-08" iyz="0" izz="1.125e-07"/>
      </inertial>
  </link>

  <joint name="back_roll_joint" type="continuous">
    <origin rpy="0 0 0" xyz="0 0 0" />
    <parent link="back_yaw_link" />
    <child link="back_roll_link" />
    <axis xyz="1 0 0" />
    <limit effort="1000.0" velocity="100.0" />
    <dynamics damping="0.0" friction="0.1"/>
  </joint>

  <link name="back_pitch_link">
    <visual>
      <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
      <material name="white"/>
    </visual>

    <collision>
      <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
    </collision>

    <inertial>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <mass value="0.015"/>
        <inertia ixx="1.35e-06" ixy="0" ixz="0" iyy="1.35e-06" iyz="0" izz="1.35e-06"/>
    </inertial>
  </link>

  <gazebo reference="back_pitch_link">
    <collision>
        <surface>
        <friction>
            <ode>
            <mu>0.5</mu>
            <mu2>0.5</mu2>
            </ode>
        </friction>
        <contact>
            <ode>
            <kp>10000000.0</kp>
            <kd>10000000.0</kd>
            </ode>
        </contact>
        </surface>
    </collision>
  </gazebo>

  <joint name="back_pitch_joint" type="continuous">
    <origin rpy="0 0 0" xyz="0 0 0" />
    <parent link="back_roll_link" />
    <child link="back_pitch_link" />
    <axis xyz="0 1 0" />
    <limit effort="1000.0" velocity="100.0" />
    <dynamics damping="0.0" friction="0.1"/>
  </joint>

<!-- Stand-off rods 0.05 kg each -->
  <link name="standoff_rod_1">
    <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.220" radius="0.01"/>
        </geometry>
        <material name="black"/>
      </visual>
    
    <collision>
      <geometry>
        <cylinder length="0.220" radius="0.01"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.05"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.0002029" ixy="0" ixz="0" iyy="0.0002029" iyz="0" izz="0.0000025"/>
    </inertial>
  </link>

  <joint name="standoff_rod_1_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.050 -0.12 0.1875" />
    <parent link="chassis" />
    <child link="standoff_rod_1" />
  </joint>


  <link name="standoff_rod_2">
    <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.220" radius="0.01"/>
        </geometry>
        <material name="black"/>
      </visual>

    <collision>
      <geometry>
        <cylinder length="0.220" radius="0.01"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.05"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.0002029" ixy="0" ixz="0" iyy="0.0002029" iyz="0" izz="0.0000025"/>
    </inertial>
  </link>

  <joint name="standoff_rod_2_joint" type="fixed">
    <origin rpy="0 0 0" xyz="-0.050 -0.12 0.1875" />
    <parent link="chassis" />
    <child link="standoff_rod_2" />
  </joint>


  <link name="standoff_rod_3">
    <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.220" radius="0.01"/>
        </geometry>
        <material name="black"/>
      </visual>
    <collision>
      <geometry>
        <cylinder length="0.220" radius="0.01"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.05"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.0002029" ixy="0" ixz="0" iyy="0.0002029" iyz="0" izz="0.0000025"/>
    </inertial>
  </link>

  <joint name="standoff_rod_3_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.050 0.12 0.1875" />
    <parent link="chassis" />
    <child link="standoff_rod_3" />
  </joint>


  <link name="standoff_rod_4">
    <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.220" radius="0.01"/>
        </geometry>
        <material name="black"/>
      </visual>
    <collision>
      <geometry>
        <cylinder length="0.220" radius="0.01"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.05"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.0002029" ixy="0" ixz="0" iyy="0.0002029" iyz="0" izz="0.0000025"/>
    </inertial>
  </link>

  <joint name="standoff_rod_4_joint" type="fixed">
    <origin rpy="0 0 0" xyz="-0.050 0.12 0.1875" />
    <parent link="chassis" />
    <child link="standoff_rod_4" />
  </joint>

<!-- Cup Holder tray 0.4 kg-->
  <link name="cup_holder_tray">
    <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.090" radius="0.16"/>
        </geometry>
        <material name="red"/>
      </visual>
    <collision>
      <geometry>
        <cylinder length="0.090" radius="0.16"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.4"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.00283" ixy="0" ixz="0" iyy="0.00283" iyz="0" izz="0.00512"/>
    </inertial>
  </link>

  <joint name="cup_holder_tray_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0.3425" />
    <parent link="chassis" />
    <child link="cup_holder_tray" />
  </joint>

<!-- Laser Position Control 0.105 kg -->
  <link name="laser_scan_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://barista_robot_description/meshes/slamtec_rplidar_s1.dae" scale="1.0 1.0 1.0"/>
      </geometry>
    </visual>

    <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/> 
        <geometry>
            <cylinder radius="0.02775" length="0.051"/>
        </geometry>
    </collision>

    <inertial>
      <mass value="0.105"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia 
        ixx="4.297289e-05" ixy="0.0" ixz="0.0" 
        iyy="4.297289e-05" iyz="0.0" 
        izz="4.042828e-05"/>
    </inertial>
  </link>

  <joint name="laser_scan_link_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.100 0.0 0.0775"/>
    <parent link="chassis"/>
    <child link="laser_scan_link"/>
  </joint>

  <!-- Laser Scanner Sensor Plugin -->
<gazebo reference="laser_scan_link">
  <sensor name="laser_sensor" type="gpu_lidar">
    <topic>/scan</topic>
    <update_rate>10</update_rate>
    <gz_frame_id>laser_scan_link</gz_frame_id>
    <lidar>
      <scan>
        <horizontal>
          <samples>360</samples>
          <resolution>1</resolution>
          <min_angle>-3.14159</min_angle>
          <max_angle>3.14159</max_angle>
        </horizontal>
      </scan>
      <range>
        <min>0.12</min>
        <max>40.0</max>
        <resolution>0.01</resolution>
      </range>
      <noise>
        <type>gaussian</type>
        <mean>0.0</mean>
        <stddev>0.01</stddev>
      </noise>
    </lidar>
    <always_on>1</always_on>
    <visualize>true</visualize>
  </sensor>
</gazebo>

  <link name="laser_scan_frame">
  </link>

  <joint name="laser_scan_frame_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="laser_scan_link"/>
    <child link="laser_scan_frame"/>
    <axis xyz="0 0 0"/>
  </joint>

<!-- PLUGINS -->
  <!-- Joint State Publisher Plugin -->
  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
        <topic>/joint_states</topic>
        <update_rate>30</update_rate>
        <!-- Publish the state of these joints -->
        <joint_name>joint_left_wheel</joint_name>
        <joint_name>joint_right_wheel</joint_name>
        <joint_name>front_yaw_joint</joint_name>
        <joint_name>back_yaw_joint</joint_name>
        <joint_name>front_roll_joint</joint_name>
        <joint_name>back_roll_joint</joint_name>
        <joint_name>front_pitch_joint</joint_name>
        <joint_name>back_pitch_joint</joint_name>
    </plugin>
  </gazebo>  

  <!-- Differential Drive Plugin -->
  <gazebo>
    <plugin
        filename="gz-sim-diff-drive-system"
        name="gz::sim::systems::DiffDrive">
        <left_joint>joint_left_wheel</left_joint>
        <right_joint>joint_right_wheel</right_joint>
        <wheel_separation>0.310</wheel_separation>
        <wheel_radius>0.0352</wheel_radius>
        <topic>/cmd_vel</topic>
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
        <publish_wheel_tf>true</publish_wheel_tf>
        <odom_topic>odom</odom_topic>
        <tf_topic>tf</tf_topic>
        <frame_id>odom</frame_id>
        <child_frame_id>base_link</child_frame_id>
    </plugin>
  </gazebo>

  <gazebo>
  <plugin
    filename="gz-sim-sensors-system"
    name="gz::sim::systems::Sensors">
    <render_engine>ogre2</render_engine>
  </plugin>
</gazebo>

</robot>